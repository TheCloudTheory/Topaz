{
  "servers": {
    "TopazMCP": {
      "type": "stdio",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "Topaz.MCP/Topaz.MCP.csproj"
      ]
    },
    "TopazMCPDocker": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "topaz/mcp"
      ]
    },
    "Topaz": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--network", "host",
        "thecloudtheory/topaz-mcp:v1.3.51-beta"
      ]
    }
  }
}