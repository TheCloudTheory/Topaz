[
  {
    "language": "C#",
    "extensions": [
      ".cs"
    ],
    "markers": [
      {
        "type": "line",
        "pattern": "//"
      },
      {
        "type": "block",
        "pattern": {
          "start": "/\\*",
          "end": "\\*/"
        }
      }
    ]
  },
  {
    "language": "Markdown",
    "extensions": [
      ".md"
    ],
    "markers": [
      {
        "type": "block",
        "pattern": {
          "start": "<!--",
          "end": "-->"
        }
      },
      {
        "type": "line",
        "pattern": "- \\[ \\]"
      }
    ]
  }
]