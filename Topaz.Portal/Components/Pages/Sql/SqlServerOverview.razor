@page "/portal/sql/{SubscriptionId:guid}/{ResourceGroupName}/{ServerName}"
@using System.Net
@using Topaz.Portal.Models.Sql
@inject ITopazClient TopazClient
@inject NavigationManager Nav

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/portal/sql">Azure SQL servers</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">@DecodedServerName</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedServerName</h1>

<SqlServerDetailsShell SubscriptionId="SubscriptionId"
                       ResourceGroupName="@DecodedRg"
                       ServerName="@DecodedServerName">
    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger" role="alert">@_error</div>
    }
    else if (_server is null)
    {
        <p class="mb-0">SQL server not found.</p>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <h5 class="card-title mb-0">Essentials</h5>
                    <button class="btn btn-sm btn-outline-danger"
                            @onclick="() => _showDeleteConfirm = true"
                            disabled="@_deletingBusy">
                        Delete
                    </button>
                </div>

                @if (_showDeleteConfirm)
                {
                    <div class="alert alert-warning d-flex align-items-center justify-content-between" role="alert">
                        <span>Delete SQL server <strong>@(_server.Name)</strong>? This cannot be undone.</span>
                        <div class="d-flex gap-2 ms-3">
                            <button class="btn btn-sm btn-danger"
                                    @onclick="DeleteServerAsync"
                                    disabled="@_deletingBusy">
                                Confirm delete
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => _showDeleteConfirm = false"
                                    disabled="@_deletingBusy">
                                Cancel
                            </button>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_deleteError))
                {
                    <div class="alert alert-danger" role="alert">@_deleteError</div>
                }

                <div class="row g-0">
                    <div class="col-12 col-xl-6">
                        <dl class="row mb-0 essentials-grid">
                            <dt class="col-5 text-muted fw-normal">Resource group</dt>
                            <dd class="col-7">
                                <a href="/resource-groups/@SubscriptionId:D/@WebUtility.UrlEncode(_server.ResourceGroupName ?? "")">
                                    @(_server.ResourceGroupName ?? "-")
                                </a>
                            </dd>

                            <dt class="col-5 text-muted fw-normal">Location</dt>
                            <dd class="col-7">@(_server.Location ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Subscription</dt>
                            <dd class="col-7">@(_server.SubscriptionName ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Subscription ID</dt>
                            <dd class="col-7"><small class="font-monospace">@(_server.SubscriptionId ?? "-")</small></dd>
                        </dl>
                    </div>

                    <div class="col-12 col-xl-6">
                        <dl class="row mb-0 essentials-grid">
                            <dt class="col-5 text-muted fw-normal">FQDN</dt>
                            <dd class="col-7">@(_server.FullyQualifiedDomainName ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Version</dt>
                            <dd class="col-7">@(_server.Version ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Status</dt>
                            <dd class="col-7">@(_server.State ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Administrator login</dt>
                            <dd class="col-7">@(_server.AdministratorLogin ?? "-")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    }
</SqlServerDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string ServerName { get; set; } = "";

    private bool _loading = true;
    private string? _error;
    private SqlServerDto? _server;

    private bool _showDeleteConfirm;
    private bool _deletingBusy;
    private string? _deleteError;

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedServerName => WebUtility.UrlDecode(ServerName);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _server = await TopazClient.GetSqlServer(SubscriptionId, DecodedRg, DecodedServerName);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DeleteServerAsync()
    {
        _deleteError = null;
        _deletingBusy = true;

        try
        {
            await TopazClient.DeleteSqlServer(SubscriptionId, DecodedRg, DecodedServerName);
            Nav.NavigateTo("/portal/sql");
        }
        catch (Exception ex)
        {
            _deleteError = ex.Message;
            _showDeleteConfirm = false;
        }
        finally
        {
            _deletingBusy = false;
        }
    }
}
