@* Topaz.Portal/Components/Pages/Entra/EntraOverviewPage.razor *@
@page "/entra"
@inject TopazClient TopazClient

<EntraTenantShell>
    <div class="card">
        <div class="card-body">
            <h3 class="card-title mb-3">Tenant overview</h3>

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold">Basics</div>
                        <div class="text-muted small">Tenant name, tenant ID, default domain, region…</div>
                        <hr />
                        <div class="small">
                            <div>
                                <span class="text-muted">Tenant:</span>
                                <span>@("_directoryInfo?.DisplayName" ?? "—")</span>
                            </div>
                            <div>
                                <span class="text-muted">Tenant ID:</span>
                                <span>@("_directoryInfo?.TenantId" ?? "—")</span>
                            </div>
                            <div><span class="text-muted">Primary domain:</span> <span>[placeholder]</span></div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold">Summary</div>
                        <div class="text-muted small">Quick counts for identity objects.</div>
                        <hr />
                        <div class="small">
                            <div><span class="text-muted">Users:</span> <span>[placeholder]</span></div>
                            <div><span class="text-muted">Groups:</span> <span>[placeholder]</span></div>
                            <div><span class="text-muted">Service principals:</span> <span>[placeholder]</span></div>
                            <div><span class="text-muted">Applications:</span> <span>[placeholder]</span></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 text-muted small">
                Wire these placeholders to your emulator’s Entra tenant model/API when ready.
            </div>
        </div>
    </div>
</EntraTenantShell>

@code
{
    //private DirectoryInfoDto? _directoryInfo;

    protected override async Task OnInitializedAsync()
    {
        await TopazClient.GetDirectoryInfo();
    }
}