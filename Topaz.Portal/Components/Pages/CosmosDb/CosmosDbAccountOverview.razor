@page "/portal/cosmos-db/{SubscriptionId:guid}/{ResourceGroupName}/{AccountName}"
@using System.Net
@using Topaz.Portal.Models.CosmosDb
@inject ITopazClient TopazClient
@inject NavigationManager Nav

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/portal/cosmos-db">Cosmos DB accounts</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">@DecodedAccountName</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedAccountName</h1>

<CosmosDbAccountDetailsShell SubscriptionId="SubscriptionId"
                              ResourceGroupName="@DecodedRg"
                              AccountName="@DecodedAccountName">
    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger" role="alert">@_error</div>
    }
    else if (_account is null)
    {
        <p class="mb-0">Cosmos DB account not found.</p>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <h5 class="card-title mb-0">Essentials</h5>
                    <button class="btn btn-sm btn-outline-danger"
                            @onclick="() => _showDeleteConfirm = true"
                            disabled="@_deletingBusy">
                        Delete
                    </button>
                </div>

                @if (_showDeleteConfirm)
                {
                    <div class="alert alert-warning d-flex align-items-center justify-content-between" role="alert">
                        <span>Delete Cosmos DB account <strong>@(_account.Name)</strong>? This cannot be undone.</span>
                        <div class="d-flex gap-2 ms-3">
                            <button class="btn btn-sm btn-danger"
                                    @onclick="DeleteAccountAsync"
                                    disabled="@_deletingBusy">
                                Confirm delete
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => _showDeleteConfirm = false"
                                    disabled="@_deletingBusy">
                                Cancel
                            </button>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_deleteError))
                {
                    <div class="alert alert-danger" role="alert">@_deleteError</div>
                }

                <div class="row g-0">
                    <div class="col-12 col-xl-6">
                        <dl class="row mb-0 essentials-grid">
                            <dt class="col-5 text-muted fw-normal">Resource group</dt>
                            <dd class="col-7">
                                <a href="/resource-groups/@SubscriptionId:D/@WebUtility.UrlEncode(_account.ResourceGroupName ?? "")">
                                    @(_account.ResourceGroupName ?? "-")
                                </a>
                            </dd>

                            <dt class="col-5 text-muted fw-normal">Location</dt>
                            <dd class="col-7">@(_account.Location ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Subscription</dt>
                            <dd class="col-7">@(_account.SubscriptionName ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Subscription ID</dt>
                            <dd class="col-7"><small class="font-monospace">@(_account.SubscriptionId ?? "-")</small></dd>
                        </dl>
                    </div>

                    <div class="col-12 col-xl-6">
                        <dl class="row mb-0 essentials-grid">
                            <dt class="col-5 text-muted fw-normal">Kind</dt>
                            <dd class="col-7">@(_account.Kind ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Provisioning state</dt>
                            <dd class="col-7">@(_account.ProvisioningState ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Document endpoint</dt>
                            <dd class="col-7"><small class="font-monospace">@(_account.DocumentEndpoint ?? "-")</small></dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    }
</CosmosDbAccountDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string AccountName { get; set; } = "";

    private bool _loading = true;
    private string? _error;
    private CosmosDbAccountDto? _account;

    private bool _showDeleteConfirm;
    private bool _deletingBusy;
    private string? _deleteError;

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedAccountName => WebUtility.UrlDecode(AccountName);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _account = await TopazClient.GetCosmosDbAccount(SubscriptionId, DecodedRg, DecodedAccountName);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DeleteAccountAsync()
    {
        _deleteError = null;
        _deletingBusy = true;

        try
        {
            await TopazClient.DeleteCosmosDbAccount(SubscriptionId, DecodedRg, DecodedAccountName);
            Nav.NavigateTo("/portal/cosmos-db");
        }
        catch (Exception ex)
        {
            _deleteError = ex.Message;
            _showDeleteConfirm = false;
        }
        finally
        {
            _deletingBusy = false;
        }
    }
}
