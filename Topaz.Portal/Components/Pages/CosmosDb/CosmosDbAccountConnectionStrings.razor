@page "/portal/cosmos-db/{SubscriptionId:guid}/{ResourceGroupName}/{AccountName}/connection-strings"
@using System.Net
@using Topaz.Portal.Models.CosmosDb
@inject ITopazClient TopazClient
@inject IJSRuntime JS

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/portal/cosmos-db">Cosmos DB accounts</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/portal/cosmos-db/{SubscriptionId:D}/{ResourceGroupName}/{AccountName}")">@DecodedAccountName</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">Connection strings</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedAccountName</h1>

<CosmosDbAccountDetailsShell SubscriptionId="SubscriptionId"
                              ResourceGroupName="@DecodedRg"
                              AccountName="@DecodedAccountName">
    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger" role="alert">@_error</div>
    }
    else if (_keys is not null)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title mb-3">Connection strings</h5>

                <ConnectionStringRow Label="Primary connection string" Value="@_keys.PrimaryConnectionString" OnCopy="CopyAsync" />
                <ConnectionStringRow Label="Secondary connection string" Value="@_keys.SecondaryConnectionString" OnCopy="CopyAsync" />
                <ConnectionStringRow Label="Account endpoint" Value="@_keys.AccountEndpoint" OnCopy="CopyAsync" />
                <ConnectionStringRow Label="Primary key" Value="@_keys.PrimaryKey" OnCopy="CopyAsync" />
                <ConnectionStringRow Label="Secondary key" Value="@_keys.SecondaryKey" OnCopy="CopyAsync" />
            </div>
        </div>
    }
</CosmosDbAccountDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string AccountName { get; set; } = "";

    private bool _loading = true;
    private string? _error;
    private CosmosDbAccountKeysDto? _keys;

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedAccountName => WebUtility.UrlDecode(AccountName);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _keys = await TopazClient.GetCosmosDbAccountKeys(SubscriptionId, DecodedRg, DecodedAccountName);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CopyAsync(string value)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
    }
}
