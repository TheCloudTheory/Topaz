@page "/key-vault/{SubscriptionId:guid}/{ResourceGroupName}/{KeyVaultName}/secrets"
@using System.Net
@using Topaz.Portal.Models.KeyVaults
@inject TopazClient TopazClient

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/key-vault">Key vaults</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/key-vault/{SubscriptionId:D}/{ResourceGroupName}/{KeyVaultName}")">@DecodedKv</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">Secrets</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedKv</h1>

<KeyVaultDetailsShell SubscriptionId="SubscriptionId"
                      ResourceGroupName="@DecodedRg"
                      KeyVaultName="@DecodedKv">

    <div class="d-flex flex-wrap gap-2 mb-3">
        <button class="btn btn-primary btn-sm" @onclick="ToggleCreate">+ Generate / Import</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshAsync" disabled="@_loading">Refresh</button>
        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleRestore">Restore Backup</button>
        <a class="btn btn-outline-secondary btn-sm"
           href="@($"/key-vault/{SubscriptionId:D}/{ResourceGroupName}/{KeyVaultName}/secrets/deleted")">
            Manage Deleted Secrets
        </a>
    </div>

    @if (_showCreate)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title mb-3">Create a Secret</h6>
                <div class="row g-2">
                    <div class="col-12 col-md-4">
                        <label class="form-label">Name</label>
                        <input class="form-control form-control-sm" @bind="_createName" @bind:event="oninput"
                               placeholder="my-secret" disabled="@_createBusy" />
                    </div>
                    <div class="col-12 col-md-5">
                        <label class="form-label">Value</label>
                        <div class="input-group input-group-sm">
                            <input class="form-control" @bind="_createValue" @bind:event="oninput"
                                   placeholder="secret value" disabled="@_createBusy" />
                            <button class="btn btn-outline-secondary" @onclick="GenerateValue"
                                    title="Generate random value" disabled="@_createBusy">&#8635;</button>
                        </div>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label">Content type <span class="text-muted">(optional)</span></label>
                        <input class="form-control form-control-sm" @bind="_createContentType"
                               placeholder="e.g. text/plain" disabled="@_createBusy" />
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(_createError))
                {
                    <div class="alert alert-danger mt-2 py-1 mb-0" role="alert">@_createError</div>
                }
                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-primary btn-sm" @onclick="CreateSecretAsync"
                            disabled="@(string.IsNullOrWhiteSpace(_createName) || string.IsNullOrWhiteSpace(_createValue) || _createBusy)">
                        @(_createBusy ? "Creating…" : "Create")
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleCreate" disabled="@_createBusy">Cancel</button>
                </div>
            </div>
        </div>
    }

    @if (_showRestore)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title mb-3">Restore Secret from Backup</h6>
                <div class="mb-2">
                    <label class="form-label">Upload backup file</label>
                    <InputFile class="form-control form-control-sm" accept=".bak,.txt,*"
                               OnChange="OnBackupFileSelectedAsync" disabled="@_restoreBusy" />
                    <div class="form-text">Select the backup file, or paste the blob manually below.</div>
                </div>
                <label class="form-label">Backup blob</label>
                <textarea class="form-control form-control-sm font-monospace" rows="3"
                          @bind="_restoreBlob" placeholder="Paste the backup blob value here…"
                          disabled="@_restoreBusy"></textarea>
                @if (!string.IsNullOrWhiteSpace(_restoreError))
                {
                    <div class="alert alert-danger mt-2 py-1 mb-0" role="alert">@_restoreError</div>
                }
                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-primary btn-sm" @onclick="RestoreAsync"
                            disabled="@(string.IsNullOrWhiteSpace(_restoreBlob) || _restoreBusy)">
                        @(_restoreBusy ? "Restoring…" : "Restore")
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleRestore" disabled="@_restoreBusy">Cancel</button>
                </div>
            </div>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <h5 class="card-title mb-3">Secrets</h5>

            @if (!string.IsNullOrWhiteSpace(_actionError))
            {
                <div class="alert alert-danger" role="alert">@_actionError</div>
            }

            @if (_loading)
            {
                <p>Loading…</p>
            }
            else if (_loadError is not null)
            {
                <div class="alert alert-danger" role="alert">@_loadError</div>
            }
            else if (_secrets.Count == 0)
            {
                <p class="mb-0 text-muted">No secrets found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Content Type</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Updated</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _secrets)
                            {
                                <tr>
                                    <td><code>@(s.Name ?? "-")</code></td>
                                    <td><small class="text-muted">@(s.ContentType ?? "-")</small></td>
                                    <td>
                                        @if (s.Enabled)
                                        {
                                            <span class="badge bg-success">Enabled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Disabled</span>
                                        }
                                    </td>
                                    <td><small class="text-muted">@(s.Created?.ToString("yyyy-MM-dd HH:mm") ?? "-")</small></td>
                                    <td><small class="text-muted">@(s.Updated?.ToString("yyyy-MM-dd HH:mm") ?? "-")</small></td>
                                    <td class="text-end">
                                        <div class="d-flex gap-1 justify-content-end">
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    @onclick="() => BackupSecretAsync(s.Name!)"
                                                    disabled="@_actionBusy" title="Download backup blob">
                                                Backup
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => DeleteSecretAsync(s.Name!)"
                                                    disabled="@_actionBusy">
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_backupBlob))
            {
                <div class="mt-3 border-top pt-3">
                    <label class="form-label fw-semibold">
                        Backup blob for <code>@_backupSecretName</code> — copy and store this securely:
                    </label>
                    <textarea class="form-control form-control-sm font-monospace" rows="3" readonly>@_backupBlob</textarea>
                </div>
            }
        </div>
    </div>

</KeyVaultDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string KeyVaultName { get; set; } = "";

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedKv => WebUtility.UrlDecode(KeyVaultName);

    private bool _loading = true;
    private string? _loadError;
    private string? _actionError;
    private bool _actionBusy;
    private IReadOnlyList<KeyVaultSecretDto> _secrets = [];
    private string? _vaultUri;

    // Create panel
    private bool _showCreate;
    private string _createName = string.Empty;
    private string _createValue = string.Empty;
    private string _createContentType = string.Empty;
    private string? _createError;
    private bool _createBusy;

    // Restore panel
    private bool _showRestore;
    private string _restoreBlob = string.Empty;
    private string? _restoreError;
    private bool _restoreBusy;

    // Backup result
    private string _backupBlob = string.Empty;
    private string? _backupSecretName;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        _actionError = null;
        _backupBlob = string.Empty;
        _backupSecretName = null;

        try
        {
            var kv = await TopazClient.GetKeyVault(SubscriptionId, DecodedRg, DecodedKv);
            if (kv?.VaultUri is null)
            {
                _loadError = "Could not resolve vault URI.";
                return;
            }

            _vaultUri = kv.VaultUri;
            _secrets = await TopazClient.ListKeyVaultSecrets(_vaultUri);
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync()
    {
        await LoadAsync();
        StateHasChanged();
    }

    private void ToggleCreate()
    {
        _showCreate = !_showCreate;
        _createName = string.Empty;
        _createValue = string.Empty;
        _createContentType = string.Empty;
        _createError = null;
    }

    private void ToggleRestore()
    {
        _showRestore = !_showRestore;
        _restoreBlob = string.Empty;
        _restoreError = null;
    }

    private async Task OnBackupFileSelectedAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        using var reader = new System.IO.StreamReader(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
        _restoreBlob = (await reader.ReadToEndAsync()).Trim();
    }

    private void GenerateValue()
    {
        _createValue = Convert.ToBase64String(System.Security.Cryptography.RandomNumberGenerator.GetBytes(32));
    }

    private async Task CreateSecretAsync()
    {
        _createError = null;
        _createBusy = true;
        try
        {
            await TopazClient.SetKeyVaultSecret(
                _vaultUri!, _createName.Trim(), _createValue,
                string.IsNullOrWhiteSpace(_createContentType) ? null : _createContentType.Trim());
            _showCreate = false;
            _createName = string.Empty;
            _createValue = string.Empty;
            _createContentType = string.Empty;
            await LoadAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _createError = ex.Message;
        }
        finally
        {
            _createBusy = false;
        }
    }

    private async Task RestoreAsync()
    {
        _restoreError = null;
        _restoreBusy = true;
        try
        {
            await TopazClient.RestoreKeyVaultSecret(_vaultUri!, _restoreBlob.Trim());
            _showRestore = false;
            _restoreBlob = string.Empty;
            await LoadAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _restoreError = ex.Message;
        }
        finally
        {
            _restoreBusy = false;
        }
    }

    private async Task DeleteSecretAsync(string name)
    {
        _actionError = null;
        _actionBusy = true;
        try
        {
            await TopazClient.DeleteKeyVaultSecret(_vaultUri!, name);
            await LoadAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _actionBusy = false;
        }
    }

    private async Task BackupSecretAsync(string name)
    {
        _actionError = null;
        _backupBlob = string.Empty;
        _backupSecretName = null;
        _actionBusy = true;
        try
        {
            _backupBlob = await TopazClient.BackupKeyVaultSecret(_vaultUri!, name);
            _backupSecretName = name;
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _actionBusy = false;
        }
    }
}

