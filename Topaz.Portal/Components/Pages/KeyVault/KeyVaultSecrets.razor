@page "/key-vault/{SubscriptionId:guid}/{ResourceGroupName}/{KeyVaultName}/secrets"
@using System.Net
@using Topaz.Portal.Models.KeyVaults
@inject TopazClient TopazClient

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/key-vault">Key vaults</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/key-vault/{SubscriptionId:D}/{ResourceGroupName}/{KeyVaultName}")">@DecodedKv</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">Secrets</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedKv</h1>

<KeyVaultDetailsShell SubscriptionId="SubscriptionId"
                      ResourceGroupName="@DecodedRg"
                      KeyVaultName="@DecodedKv">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title mb-3">Secrets</h5>

            @if (_loading)
            {
                <p>Loading…</p>
            }
            else if (_error is not null)
            {
                <div class="alert alert-danger" role="alert">@_error</div>
            }
            else if (_secrets.Count == 0)
            {
                <p class="mb-0">No secrets found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Name</th>
                            <th>Enabled</th>
                            <th>Created</th>
                            <th>Updated</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var s in _secrets)
                        {
                            <tr>
                                <td>@(s.Name ?? s.Id ?? "-")</td>
                                <td>
                                    @if (s.Enabled)
                                    {
                                        <span class="badge text-bg-success">Enabled</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">Disabled</span>
                                    }
                                </td>
                                <td><small class="text-muted">@(s.Created?.ToString("yyyy-MM-dd HH:mm") ?? "-")</small></td>
                                <td><small class="text-muted">@(s.Updated?.ToString("yyyy-MM-dd HH:mm") ?? "-")</small></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</KeyVaultDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string KeyVaultName { get; set; } = "";

    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<KeyVaultSecretDto> _secrets = [];

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedKv => WebUtility.UrlDecode(KeyVaultName);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var kv = await TopazClient.GetKeyVault(SubscriptionId, DecodedRg, DecodedKv);
            if (kv?.VaultUri is null)
            {
                _error = "Could not resolve vault URI.";
                return;
            }

            _secrets = await TopazClient.ListKeyVaultSecrets(kv.VaultUri);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
