@page "/key-vault/{SubscriptionId:guid}/{ResourceGroupName}/{KeyVaultName}/secrets/deleted"
@using System.Net
@using Topaz.Portal.Models.KeyVaults
@inject TopazClient TopazClient

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/key-vault">Key vaults</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/key-vault/{SubscriptionId:D}/{ResourceGroupName}/{KeyVaultName}")">@DecodedKv</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/key-vault/{SubscriptionId:D}/{ResourceGroupName}/{KeyVaultName}/secrets")">Secrets</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">Deleted Secrets</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedKv</h1>

<KeyVaultDetailsShell SubscriptionId="SubscriptionId"
                      ResourceGroupName="@DecodedRg"
                      KeyVaultName="@DecodedKv">

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a class="btn btn-outline-secondary btn-sm"
           href="@($"/key-vault/{SubscriptionId:D}/{ResourceGroupName}/{KeyVaultName}/secrets")">
            &larr; Back to Secrets
        </a>
        <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshAsync" disabled="@_loading">Refresh</button>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title mb-3">Deleted Secrets</h5>

            @if (!string.IsNullOrWhiteSpace(_actionError))
            {
                <div class="alert alert-danger" role="alert">@_actionError</div>
            }

            @if (_loading)
            {
                <p>Loading…</p>
            }
            else if (_loadError is not null)
            {
                <div class="alert alert-danger" role="alert">@_loadError</div>
            }
            else if (_deleted.Count == 0)
            {
                <p class="mb-0 text-muted">No deleted secrets found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Content Type</th>
                                <th>Status</th>
                                <th>Deleted</th>
                                <th>Purge Date</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _deleted)
                            {
                                <tr>
                                    <td><code>@(s.Name ?? "-")</code></td>
                                    <td><small class="text-muted">@(s.ContentType ?? "-")</small></td>
                                    <td>
                                        @if (s.Enabled)
                                        {
                                            <span class="badge bg-success">Enabled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Disabled</span>
                                        }
                                    </td>
                                    <td><small class="text-muted">@(s.DeletedDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</small></td>
                                    <td><small class="text-muted">@(s.ScheduledPurgeDate?.ToString("yyyy-MM-dd HH:mm") ?? "-")</small></td>
                                    <td class="text-end">
                                        <div class="d-flex gap-1 justify-content-end">
                                            <button class="btn btn-outline-primary btn-sm"
                                                    @onclick="() => RecoverAsync(s.Name!)"
                                                    disabled="@_actionBusy">
                                                Recover
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm"
                                                    @onclick="() => PurgeAsync(s.Name!)"
                                                    disabled="@_actionBusy">
                                                Purge
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

</KeyVaultDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string KeyVaultName { get; set; } = "";

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedKv => WebUtility.UrlDecode(KeyVaultName);

    private bool _loading = true;
    private string? _loadError;
    private string? _actionError;
    private bool _actionBusy;
    private IReadOnlyList<KeyVaultDeletedSecretDto> _deleted = [];
    private string? _vaultUri;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        _actionError = null;

        try
        {
            var kv = await TopazClient.GetKeyVault(SubscriptionId, DecodedRg, DecodedKv);
            if (kv?.VaultUri is null)
            {
                _loadError = "Could not resolve vault URI.";
                return;
            }

            _vaultUri = kv.VaultUri;
            _deleted = await TopazClient.ListDeletedKeyVaultSecrets(_vaultUri);
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync()
    {
        await LoadAsync();
        StateHasChanged();
    }

    private async Task RecoverAsync(string name)
    {
        _actionError = null;
        _actionBusy = true;
        try
        {
            await TopazClient.RecoverDeletedKeyVaultSecret(_vaultUri!, name);
            await LoadAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _actionBusy = false;
        }
    }

    private async Task PurgeAsync(string name)
    {
        _actionError = null;
        _actionBusy = true;
        try
        {
            await TopazClient.PurgeDeletedKeyVaultSecret(_vaultUri!, name);
            await LoadAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _actionBusy = false;
        }
    }
}
