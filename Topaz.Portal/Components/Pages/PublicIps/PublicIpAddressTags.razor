@page "/portal/public-ip-addresses/{SubscriptionId:guid}/{ResourceGroupName}/{PipName}/tags"
@using System.Net
@using Topaz.Portal.Models.PublicIps
@inject ITopazClient TopazClient

<PageTitle>Tags — @DecodedName — Topaz Portal</PageTitle>

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/portal/public-ip-addresses">Public IP addresses</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/portal/public-ip-addresses/{SubscriptionId:D}/{ResourceGroupName}/{PipName}")">@DecodedName</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">Tags</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedName</h1>

<PublicIpAddressDetailsShell SubscriptionId="SubscriptionId"
                              ResourceGroupName="@DecodedRg"
                              PipName="@DecodedName">
    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_loadError is not null)
    {
        <div class="alert alert-danger" role="alert">@_loadError</div>
    }
    else
    {
        <TagsPanel Tags="_tags"
                   OnAdd="AddTagAsync"
                   OnRemove="RemoveTagAsync"
                   OnEdit="EditTagAsync" />
    }
</PublicIpAddressDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string PipName { get; set; } = "";

    private bool _loading = true;
    private string? _loadError;
    private Dictionary<string, string> _tags = [];

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedName => WebUtility.UrlDecode(PipName);

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;

        try
        {
            var pip = await TopazClient.GetPublicIpAddress(SubscriptionId, DecodedRg, DecodedName);

            if (pip is null)
            {
                _tags = [];
                _loadError = "Public IP address not found.";
                return;
            }

            _tags = new Dictionary<string, string>(pip.Tags, StringComparer.OrdinalIgnoreCase);
        }
        catch (Exception ex)
        {
            _tags = [];
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<string?> AddTagAsync(string tag, string value)
    {
        try
        {
            await TopazClient.CreateOrUpdatePublicIpAddressTag(SubscriptionId, DecodedRg, DecodedName, tag, value);
            await LoadAsync();
            StateHasChanged();
            return null;
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }

    private async Task<string?> RemoveTagAsync(string key)
    {
        try
        {
            await TopazClient.DeletePublicIpAddressTag(SubscriptionId, DecodedRg, DecodedName, key);
            await LoadAsync();
            StateHasChanged();
            return null;
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }

    private async Task<string?> EditTagAsync(string tag, string value)
    {
        try
        {
            await TopazClient.CreateOrUpdatePublicIpAddressTag(SubscriptionId, DecodedRg, DecodedName, tag, value);
            await LoadAsync();
            StateHasChanged();
            return null;
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }
}
