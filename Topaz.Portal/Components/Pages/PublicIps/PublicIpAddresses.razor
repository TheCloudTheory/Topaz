@page "/portal/public-ip-addresses"
@using System.Net
@using Topaz.Portal.Models.PublicIps
@using Topaz.Portal.Models.ResourceGroups
@using Topaz.Portal.Models.Subscriptions
@using Topaz.Portal.Components.Shared
@inject ITopazClient TopazClient
@inject NavigationManager Nav

<PageTitle>Public IP addresses — Topaz Portal</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="mb-0">Public IP addresses</h1>

    <button class="btn btn-primary btn-sm"
            @onclick="ToggleCreate"
            disabled="@(_loading || _creatingBusy)">
        New public IP address
    </button>
</div>

<div class="row g-3">
    <div class="@(_showCreate ? "col-12 col-lg-8" : "col-12")">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <strong>Filter</strong>
                        <span class="text-muted small">
                            @(_selectedSubscriptionIds.Count == 0 ? "All subscriptions" : $"{_selectedSubscriptionIds.Count} selected")
                        </span>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="ToggleFilter"
                                disabled="@_loading">
                            @(_showFilter ? "Hide" : "Show")
                        </button>

                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="ClearFilter"
                                disabled="@(_loading || _selectedSubscriptionIds.Count == 0)">
                            Clear
                        </button>
                    </div>
                </div>

                @if (_showFilter)
                {
                    <div class="border rounded p-2 mb-3" style="max-height: 180px; overflow:auto;">
                        @if (_subscriptions.Length == 0)
                        {
                            <div class="text-muted small">No subscriptions loaded.</div>
                        }
                        else
                        {
                            @foreach (var s in _subscriptions)
                            {
                                var id = s.SubscriptionId ?? "";
                                var isChecked = !string.IsNullOrWhiteSpace(id) && _selectedSubscriptionIds.Contains(id);

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="@($"sub-filter-{id}")"
                                           checked="@isChecked"
                                           @onchange="(e) => OnSubscriptionFilterChanged(id, e)" />
                                    <label class="form-check-label" for="@($"sub-filter-{id}")">
                                        @(s.DisplayName ?? "(no name)")
                                        <span class="text-muted small">(@id)</span>
                                    </label>
                                </div>
                            }
                        }
                    </div>
                }

                @if (_loading)
                {
                    <p>Loading…</p>
                }
                else if (_error is not null)
                {
                    <div class="alert alert-danger" role="alert">@_error</div>
                }
                else if (FilteredPips.Length == 0)
                {
                    <p class="mb-0">No public IP addresses found.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>IP address</th>
                                    <th>Allocation</th>
                                    <th>Version</th>
                                    <th>SKU</th>
                                    <th>Location</th>
                                    <th>Resource group</th>
                                    <th>Subscription</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pip in FilteredPips)
                                {
                                    <tr>
                                        <td>
                                            @if (Guid.TryParse(pip.SubscriptionId, out var subId) &&
                                                 !string.IsNullOrWhiteSpace(pip.ResourceGroupName) &&
                                                 !string.IsNullOrWhiteSpace(pip.Name))
                                            {
                                                <a href="@GetPipHref(subId, pip.ResourceGroupName, pip.Name)">@pip.Name</a>
                                            }
                                            else
                                            {
                                                @(pip.Name ?? "(unknown)")
                                            }
                                        </td>
                                        <td><code>@(pip.IpAddress ?? "-")</code></td>
                                        <td>@(pip.AllocationMethod ?? "-")</td>
                                        <td>@(pip.IpVersion ?? "-")</td>
                                        <td>@(pip.Sku ?? "-")</td>
                                        <td><code>@(pip.Location ?? "-")</code></td>
                                        <td>@(pip.ResourceGroupName ?? "-")</td>
                                        <td>@(pip.SubscriptionName ?? "(unknown)")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (_showCreate)
    {
        <div class="col-12 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between mb-3">
                        <h5 class="card-title mb-0">Create public IP address</h5>

                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="CloseCreate"
                                disabled="@_creatingBusy">
                            Close
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_createError))
                    {
                        <div class="alert alert-danger" role="alert">@_createError</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Subscription</label>
                        <select class="form-select"
                                @bind="_createSubscriptionId"
                                @bind:after="OnCreateSubscriptionChangedAsync"
                                disabled="@_creatingBusy">
                            <option value="">Select a subscription…</option>
                            @foreach (var s in _subscriptions)
                            {
                                <option value="@(s.SubscriptionId ?? "")">
                                    @(s.DisplayName ?? "(no name)") (@(s.SubscriptionId ?? ""))
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Resource group</label>
                        <select class="form-select"
                                @bind="_createResourceGroupName"
                                disabled="@(_creatingBusy || _rgLoading || string.IsNullOrWhiteSpace(_createSubscriptionId))">
                            <option value="">@(_rgLoading ? "Loading…" : (string.IsNullOrWhiteSpace(_createSubscriptionId) ? "Select a subscription first" : "Select a resource group…"))</option>
                            @foreach (var rg in _resourceGroupOptions)
                            {
                                <option value="@(rg.Name ?? "")">@(rg.Name ?? "")</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control"
                               @bind="_createName"
                               placeholder="e.g. my-public-ip"
                               disabled="@_creatingBusy" />
                    </div>

                    <LocationDropdown
                        SelectedLocation="@_createLocation"
                        OnLocationChanged="OnLocationChanged"
                        Disabled="@_creatingBusy" />

                    <div class="mb-3">
                        <label class="form-label">SKU</label>
                        <select class="form-select" @bind="_createSku" disabled="@_creatingBusy">
                            <option value="Standard">Standard</option>
                            <option value="Basic">Basic</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Allocation</label>
                        <select class="form-select" @bind="_createAllocationMethod" disabled="@_creatingBusy">
                            <option value="Static">Static</option>
                            <option value="Dynamic">Dynamic</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">IP version</label>
                        <select class="form-select" @bind="_createIpVersion" disabled="@_creatingBusy">
                            <option value="IPv4">IPv4</option>
                            <option value="IPv6">IPv6</option>
                        </select>
                    </div>

                    <div class="d-grid gap-2 mt-3">
                        <button class="btn btn-success"
                                @onclick="CreatePipAsync"
                                disabled="@_creatingBusy">
                            @(_creatingBusy ? "Creating…" : "Create")
                        </button>

                        <button class="btn btn-outline-secondary"
                                @onclick="CloseCreate"
                                disabled="@_creatingBusy">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private PublicIpAddressDto[] _pips = [];
    private SubscriptionDto[] _subscriptions = [];
    private bool _showFilter = true;
    private readonly HashSet<string> _selectedSubscriptionIds = new(StringComparer.OrdinalIgnoreCase);

    private bool _showCreate;
    private bool _creatingBusy;
    private string? _createError;
    private string _createSubscriptionId = "";
    private string _createResourceGroupName = "";
    private string _createName = "";
    private string _createLocation = "westeurope";
    private string _createAllocationMethod = "Static";
    private string _createIpVersion = "IPv4";
    private string _createSku = "Standard";
    private bool _rgLoading;
    private ResourceGroupDto[] _resourceGroupOptions = [];

    private PublicIpAddressDto[] FilteredPips =>
        _selectedSubscriptionIds.Count == 0
            ? _pips
            : _pips.Where(p =>
                !string.IsNullOrWhiteSpace(p.SubscriptionId) &&
                _selectedSubscriptionIds.Contains(p.SubscriptionId))
            .ToArray();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var subsTask = TopazClient.ListSubscriptions();
            var pipsTask = TopazClient.ListPublicIpAddresses();

            await Task.WhenAll(subsTask, pipsTask);

            _subscriptions = subsTask.Result.Value;
            _pips = pipsTask.Result.Value;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetPipHref(Guid subscriptionId, string resourceGroupName, string pipName)
        => $"/portal/public-ip-addresses/{subscriptionId:D}/{WebUtility.UrlEncode(resourceGroupName)}/{WebUtility.UrlEncode(pipName)}";

    private void ToggleFilter() => _showFilter = !_showFilter;
    private void ClearFilter() => _selectedSubscriptionIds.Clear();
    private void OnLocationChanged(string location) => _createLocation = location;

    private void OnSubscriptionFilterChanged(string subscriptionId, ChangeEventArgs e)
    {
        var isChecked = e.Value is true;
        if (isChecked)
            _selectedSubscriptionIds.Add(subscriptionId);
        else
            _selectedSubscriptionIds.Remove(subscriptionId);
    }

    private void ToggleCreate()
    {
        _showCreate = !_showCreate;
        _createError = null;
    }

    private void CloseCreate()
    {
        _showCreate = false;
        _createError = null;
        _createSubscriptionId = "";
        _createResourceGroupName = "";
        _createName = "";
        _createLocation = "westeurope";
        _createAllocationMethod = "Static";
        _createIpVersion = "IPv4";
        _createSku = "Standard";
        _resourceGroupOptions = [];
    }

    private async Task OnCreateSubscriptionChangedAsync()
    {
        _createResourceGroupName = "";
        _resourceGroupOptions = [];

        if (!Guid.TryParse(_createSubscriptionId, out var subId))
            return;

        _rgLoading = true;
        try
        {
            var rgs = await TopazClient.ListResourceGroups(subId);
            _resourceGroupOptions = rgs.Value;
        }
        catch
        {
            _resourceGroupOptions = [];
        }
        finally
        {
            _rgLoading = false;
        }
    }

    private async Task CreatePipAsync()
    {
        _createError = null;

        if (string.IsNullOrWhiteSpace(_createSubscriptionId))
        {
            _createError = "Please select a subscription.";
            return;
        }

        if (!Guid.TryParse(_createSubscriptionId, out var subscriptionId))
        {
            _createError = "Subscription ID is invalid.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_createResourceGroupName))
        {
            _createError = "Please select a resource group.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_createName))
        {
            _createError = "Please enter a name.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_createLocation))
        {
            _createError = "Please select a location.";
            return;
        }

        _creatingBusy = true;
        try
        {
            await TopazClient.CreatePublicIpAddress(
                subscriptionId,
                _createResourceGroupName,
                _createName,
                _createLocation,
                _createAllocationMethod,
                _createIpVersion,
                _createSku);

            CloseCreate();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _createError = ex.Message;
        }
        finally
        {
            _creatingBusy = false;
        }
    }
}
