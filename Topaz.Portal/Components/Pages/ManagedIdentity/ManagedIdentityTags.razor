@page "/managed-identities/{SubscriptionId:guid}/{ResourceGroupName}/{IdentityName}/tags"
@using System.Net
@using Topaz.Portal.Models.ManagedIdentities
@inject ITopazClient TopazClient

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/managed-identities">Managed identities</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/managed-identities/{SubscriptionId:D}/{ResourceGroupName}/{IdentityName}")">@DecodedName</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">Tags</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedName</h1>

<ManagedIdentityDetailsShell SubscriptionId="SubscriptionId"
                              ResourceGroupName="@DecodedRg"
                              IdentityName="@DecodedName">
    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_loadError is not null)
    {
        <div class="alert alert-danger" role="alert">@_loadError</div>
    }
    else
    {
        <TagsPanel Tags="_tags"
                   OnAdd="AddTagAsync"
                   OnRemove="RemoveTagAsync" />
    }
</ManagedIdentityDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string IdentityName { get; set; } = "";

    private bool _loading = true;
    private string? _loadError;
    private Dictionary<string, string> _tags = [];

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedName => WebUtility.UrlDecode(IdentityName);

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;

        try
        {
            var identity = await TopazClient.GetManagedIdentity(SubscriptionId, DecodedRg, DecodedName);

            if (identity is null)
            {
                _tags = [];
                _loadError = "Managed identity not found.";
                return;
            }

            _tags = new Dictionary<string, string>(identity.Tags, StringComparer.OrdinalIgnoreCase);
        }
        catch (Exception ex)
        {
            _tags = [];
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<string?> AddTagAsync(string tag, string value)
    {
        try
        {
            await TopazClient.CreateOrUpdateManagedIdentityTag(SubscriptionId, DecodedRg, DecodedName, tag, value);
            await LoadAsync();
            StateHasChanged();
            return null;
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }

    private async Task<string?> RemoveTagAsync(string key)
    {
        try
        {
            await TopazClient.DeleteManagedIdentityTag(SubscriptionId, DecodedRg, DecodedName, key);
            await LoadAsync();
            StateHasChanged();
            return null;
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }
}
