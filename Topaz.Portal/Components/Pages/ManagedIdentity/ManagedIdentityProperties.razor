@page "/managed-identities/{SubscriptionId:guid}/{ResourceGroupName}/{IdentityName}/properties"
@using System.Net
@using Topaz.Portal.Models.ManagedIdentities
@inject ITopazClient TopazClient

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/managed-identities">Managed identities</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/managed-identities/{SubscriptionId:D}/{ResourceGroupName}/{IdentityName}")">@DecodedName</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">Properties</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedName</h1>

<ManagedIdentityDetailsShell SubscriptionId="SubscriptionId"
                              ResourceGroupName="@DecodedRg"
                              IdentityName="@DecodedName">
    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger" role="alert">@_error</div>
    }
    else if (_identity is null)
    {
        <p class="mb-0">Managed identity not found.</p>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-4">Properties</h5>

                <dl class="row">
                    <dt class="col-sm-4 text-muted fw-normal">Name</dt>
                    <dd class="col-sm-8">@(_identity.Name ?? "-")</dd>

                    <dt class="col-sm-4 text-muted fw-normal">Location</dt>
                    <dd class="col-sm-8">@(_identity.Location ?? "-")</dd>

                    <dt class="col-sm-4 text-muted fw-normal">Resource group</dt>
                    <dd class="col-sm-8">@(_identity.ResourceGroupName ?? "-")</dd>

                    <dt class="col-sm-4 text-muted fw-normal">Subscription ID</dt>
                    <dd class="col-sm-8"><code>@(_identity.SubscriptionId ?? "-")</code></dd>

                    <dt class="col-sm-4 text-muted fw-normal">Client ID</dt>
                    <dd class="col-sm-8"><code>@(_identity.ClientId ?? "-")</code></dd>

                    <dt class="col-sm-4 text-muted fw-normal">Object (principal) ID</dt>
                    <dd class="col-sm-8"><code>@(_identity.PrincipalId ?? "-")</code></dd>

                    <dt class="col-sm-4 text-muted fw-normal">Tenant ID</dt>
                    <dd class="col-sm-8"><code>@(_identity.TenantId ?? "-")</code></dd>

                    <dt class="col-sm-4 text-muted fw-normal">Provisioning state</dt>
                    <dd class="col-sm-8">@(_identity.ProvisioningState ?? "-")</dd>
                </dl>
            </div>
        </div>
    }
</ManagedIdentityDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string IdentityName { get; set; } = "";

    private bool _loading = true;
    private string? _error;
    private ManagedIdentityDto? _identity;

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedName => WebUtility.UrlDecode(IdentityName);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _identity = await TopazClient.GetManagedIdentity(SubscriptionId, DecodedRg, DecodedName);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
