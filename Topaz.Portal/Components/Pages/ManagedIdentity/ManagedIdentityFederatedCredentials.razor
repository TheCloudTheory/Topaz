@page "/managed-identities/{SubscriptionId:guid}/{ResourceGroupName}/{IdentityName}/federated-credentials"
@using System.Net
@using Topaz.Portal.Models.ManagedIdentities
@inject ITopazClient TopazClient

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/managed-identities">Managed identities</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/managed-identities/{SubscriptionId:D}/{ResourceGroupName}/{IdentityName}")">@DecodedName</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">Federated credentials</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedName</h1>

<ManagedIdentityDetailsShell SubscriptionId="SubscriptionId"
                              ResourceGroupName="@DecodedRg"
                              IdentityName="@DecodedName">
    <div class="row g-3">
        <div class="@(_showCreate ? "col-12 col-lg-7" : "col-12")">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between mb-3">
                        <h5 class="card-title mb-0">Federated credentials</h5>
                        <button class="btn btn-sm btn-primary"
                                @onclick="ToggleCreate"
                                disabled="@(_loading || _savingBusy)">
                            Add credential
                        </button>
                    </div>

                    @if (_loading)
                    {
                        <p>Loading…</p>
                    }
                    else if (_loadError is not null)
                    {
                        <div class="alert alert-danger" role="alert">@_loadError</div>
                    }
                    else if (_credentials.Length == 0)
                    {
                        <p class="mb-0 text-muted">No federated credentials configured.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Issuer</th>
                                        <th>Subject</th>
                                        <th>Audiences</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cred in _credentials)
                                    {
                                        <tr>
                                            <td>@(cred.Name ?? "-")</td>
                                            <td><small class="font-monospace text-break">@(cred.Issuer ?? "-")</small></td>
                                            <td><small class="font-monospace">@(cred.Subject ?? "-")</small></td>
                                            <td>
                                                @foreach (var audience in cred.Audiences)
                                                {
                                                    <span class="badge bg-secondary me-1">@audience</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => DeleteCredentialAsync(cred.Name!)"
                                                        disabled="@_savingBusy">
                                                    Remove
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (_showCreate)
        {
            <div class="col-12 col-lg-5">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-start justify-content-between mb-3">
                            <h5 class="card-title mb-0">Add federated credential</h5>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="CloseCreate"
                                    disabled="@_savingBusy">
                                Close
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_createError))
                        {
                            <div class="alert alert-danger" role="alert">@_createError</div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Credential name</label>
                            <input class="form-control"
                                   @bind="_createName"
                                   placeholder="e.g. github-actions"
                                   disabled="@_savingBusy" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Issuer URL</label>
                            <input class="form-control"
                                   @bind="_createIssuer"
                                   placeholder="e.g. https://token.actions.githubusercontent.com"
                                   disabled="@_savingBusy" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <input class="form-control"
                                   @bind="_createSubject"
                                   placeholder="e.g. repo:myorg/myrepo:ref:refs/heads/main"
                                   disabled="@_savingBusy" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Audience</label>
                            <input class="form-control"
                                   @bind="_createAudience"
                                   placeholder="api://AzureADTokenExchange"
                                   disabled="@_savingBusy" />
                            <div class="form-text">Typically <code>api://AzureADTokenExchange</code>.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-success"
                                    @onclick="CreateCredentialAsync"
                                    disabled="@_savingBusy">
                                Add
                            </button>
                            <button class="btn btn-outline-secondary"
                                    @onclick="CloseCreate"
                                    disabled="@_savingBusy">
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</ManagedIdentityDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string IdentityName { get; set; } = "";

    private bool _loading = true;
    private string? _loadError;
    private FederatedCredentialDto[] _credentials = [];

    private bool _showCreate;
    private bool _savingBusy;
    private string? _createError;
    private string _createName = "";
    private string _createIssuer = "";
    private string _createSubject = "";
    private string _createAudience = "api://AzureADTokenExchange";

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedName => WebUtility.UrlDecode(IdentityName);

    protected override async Task OnParametersSetAsync()
    {
        await LoadCredentialsAsync();
    }

    private async Task LoadCredentialsAsync()
    {
        _loading = true;
        _loadError = null;

        try
        {
            var result = await TopazClient.ListFederatedCredentials(SubscriptionId, DecodedRg, DecodedName);
            _credentials = result.Value;
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleCreate()
    {
        _showCreate = !_showCreate;
        _createError = null;
    }

    private void CloseCreate()
    {
        _showCreate = false;
        _createError = null;
        _createName = "";
        _createIssuer = "";
        _createSubject = "";
        _createAudience = "api://AzureADTokenExchange";
    }

    private async Task CreateCredentialAsync()
    {
        _createError = null;

        if (string.IsNullOrWhiteSpace(_createName))
        {
            _createError = "Credential name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_createIssuer))
        {
            _createError = "Issuer URL is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_createSubject))
        {
            _createError = "Subject is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_createAudience))
        {
            _createError = "Audience is required.";
            return;
        }

        _savingBusy = true;
        try
        {
            await TopazClient.CreateFederatedCredential(
                SubscriptionId,
                DecodedRg,
                DecodedName,
                _createName.Trim(),
                _createIssuer.Trim(),
                _createSubject.Trim(),
                [_createAudience.Trim()]);

            CloseCreate();
            await LoadCredentialsAsync();
        }
        catch (Exception ex)
        {
            _createError = ex.Message;
        }
        finally
        {
            _savingBusy = false;
        }
    }

    private async Task DeleteCredentialAsync(string credentialName)
    {
        _savingBusy = true;
        try
        {
            await TopazClient.DeleteFederatedCredential(SubscriptionId, DecodedRg, DecodedName, credentialName);
            await LoadCredentialsAsync();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _savingBusy = false;
        }
    }
}
