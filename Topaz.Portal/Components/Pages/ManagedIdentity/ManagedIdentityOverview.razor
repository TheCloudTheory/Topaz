@page "/managed-identities/{SubscriptionId:guid}/{ResourceGroupName}/{IdentityName}"
@using System.Net
@using Topaz.Portal.Models.ManagedIdentities
@inject ITopazClient TopazClient
@inject NavigationManager Nav

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/managed-identities">Managed identities</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">@DecodedName</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedName</h1>

<ManagedIdentityDetailsShell SubscriptionId="SubscriptionId"
                              ResourceGroupName="@DecodedRg"
                              IdentityName="@DecodedName">
    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger" role="alert">@_error</div>
    }
    else if (_identity is null)
    {
        <p class="mb-0">Managed identity not found.</p>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <h5 class="card-title mb-0">Essentials</h5>
                    <button class="btn btn-sm btn-outline-danger"
                            @onclick="() => _showDeleteConfirm = true"
                            disabled="@_deletingBusy">
                        Delete
                    </button>
                </div>

                @if (_showDeleteConfirm)
                {
                    <div class="alert alert-warning d-flex align-items-center justify-content-between" role="alert">
                        <span>Delete <strong>@(_identity.Name)</strong>? This cannot be undone.</span>
                        <div class="d-flex gap-2 ms-3">
                            <button class="btn btn-sm btn-danger"
                                    @onclick="DeleteIdentityAsync"
                                    disabled="@_deletingBusy">
                                Confirm delete
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => _showDeleteConfirm = false"
                                    disabled="@_deletingBusy">
                                Cancel
                            </button>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_deleteError))
                {
                    <div class="alert alert-danger" role="alert">@_deleteError</div>
                }

                <div class="row g-0">
                    <div class="col-12 col-xl-6">
                        <dl class="row mb-0 essentials-grid">
                            <dt class="col-5 text-muted fw-normal">Resource group</dt>
                            <dd class="col-7">
                                <a href="/resource-groups/@SubscriptionId:D/@WebUtility.UrlEncode(_identity.ResourceGroupName ?? "")">
                                    @(_identity.ResourceGroupName ?? "-")
                                </a>
                            </dd>

                            <dt class="col-5 text-muted fw-normal">Location</dt>
                            <dd class="col-7">@(_identity.Location ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Subscription</dt>
                            <dd class="col-7">@(_identity.SubscriptionName ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Subscription ID</dt>
                            <dd class="col-7"><small class="font-monospace">@(_identity.SubscriptionId ?? "-")</small></dd>
                        </dl>
                    </div>

                    <div class="col-12 col-xl-6">
                        <dl class="row mb-0 essentials-grid">
                            <dt class="col-5 text-muted fw-normal">Client ID</dt>
                            <dd class="col-7"><small class="font-monospace">@(_identity.ClientId ?? "-")</small></dd>

                            <dt class="col-5 text-muted fw-normal">Object (principal) ID</dt>
                            <dd class="col-7"><small class="font-monospace">@(_identity.PrincipalId ?? "-")</small></dd>

                            <dt class="col-5 text-muted fw-normal">Provisioning state</dt>
                            <dd class="col-7">@(_identity.ProvisioningState ?? "-")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    }
</ManagedIdentityDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string IdentityName { get; set; } = "";

    private bool _loading = true;
    private string? _error;
    private ManagedIdentityDto? _identity;

    private bool _showDeleteConfirm;
    private bool _deletingBusy;
    private string? _deleteError;

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedName => WebUtility.UrlDecode(IdentityName);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _identity = await TopazClient.GetManagedIdentity(SubscriptionId, DecodedRg, DecodedName);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DeleteIdentityAsync()
    {
        _deleteError = null;
        _deletingBusy = true;

        try
        {
            await TopazClient.DeleteManagedIdentity(SubscriptionId, DecodedRg, DecodedName);
            Nav.NavigateTo("/managed-identities");
        }
        catch (Exception ex)
        {
            _deleteError = ex.Message;
            _showDeleteConfirm = false;
        }
        finally
        {
            _deletingBusy = false;
        }
    }
}
