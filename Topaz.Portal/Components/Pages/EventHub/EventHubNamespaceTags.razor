@page "/portal/event-hubs/{SubscriptionId:guid}/{ResourceGroupName}/{NamespaceName}/tags"
@using System.Net
@using Topaz.Portal.Models.EventHubs
@inject ITopazClient TopazClient

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/portal/event-hubs">Event Hubs</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/portal/event-hubs/{SubscriptionId:D}/{ResourceGroupName}/{NamespaceName}")">@DecodedName</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">Tags</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedName</h1>

<EventHubNamespaceDetailsShell SubscriptionId="SubscriptionId"
                                ResourceGroupName="@DecodedRg"
                                NamespaceName="@DecodedName">
    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_loadError is not null)
    {
        <div class="alert alert-danger" role="alert">@_loadError</div>
    }
    else
    {
        <TagsPanel Tags="_tags"
                   OnAdd="AddTagAsync"
                   OnRemove="RemoveTagAsync" />
    }
</EventHubNamespaceDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string NamespaceName { get; set; } = "";

    private bool _loading = true;
    private string? _loadError;
    private Dictionary<string, string> _tags = [];

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedName => WebUtility.UrlDecode(NamespaceName);

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;

        try
        {
            var ns = await TopazClient.GetEventHubNamespace(SubscriptionId, DecodedRg, DecodedName);

            if (ns is null)
            {
                _tags = [];
                _loadError = "Namespace not found.";
                return;
            }

            _tags = new Dictionary<string, string>(ns.Tags, StringComparer.OrdinalIgnoreCase);
        }
        catch (Exception ex)
        {
            _tags = [];
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<string?> AddTagAsync(string tag, string value)
    {
        try
        {
            await TopazClient.CreateOrUpdateEventHubNamespaceTag(SubscriptionId, DecodedRg, DecodedName, tag, value);
            await LoadAsync();
            StateHasChanged();
            return null;
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }

    private async Task<string?> RemoveTagAsync(string key)
    {
        try
        {
            await TopazClient.DeleteEventHubNamespaceTag(SubscriptionId, DecodedRg, DecodedName, key);
            await LoadAsync();
            StateHasChanged();
            return null;
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }
}
