@* Topaz.Portal/Components/Pages/ResourceGroups/ResourceGroupTags.razor *@
@page "/resource-groups/{SubscriptionId:guid}/{ResourceGroupName}/tags"
@using System.Net
@using Topaz.Portal.Models.ResourceGroups
@inject TopazClient TopazClient

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/subscriptions">Subscriptions</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/subscriptions/{SubscriptionId:D}")">@(_rg?.SubscriptionName ?? "Subscription")</BreadcrumbItem>
    <BreadcrumbItem Href="/resource-groups">Resource Groups</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/resource-groups/{SubscriptionId:D}/{ResourceGroupName}")">@DecodedName</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">Tags</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedName</h1>

<ResourceGroupDetailsShell SubscriptionId="SubscriptionId" ResourceGroupName="@DecodedName">
    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_loadError is not null)
    {
        <div class="alert alert-danger" role="alert">
            @_loadError
        </div>
    }
    else
    {
        <TagsPanel Tags="_tags"
                   OnAdd="AddTagAsync"
                   OnRemove="RemoveTagAsync" />
    }
</ResourceGroupDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";

    private string DecodedName => WebUtility.UrlDecode(ResourceGroupName) ?? ResourceGroupName;

    private bool _loading = true;
    private string? _loadError;
    private Dictionary<string, string> _tags = [];
    private ResourceGroupDto? _rg;

    protected override async Task OnParametersSetAsync()
    {
        await LoadResourceGroupAsync();
    }

    private async Task LoadResourceGroupAsync()
    {
        _loading = true;
        _loadError = null;

        try
        {
            _rg = await TopazClient.GetResourceGroup(SubscriptionId, DecodedName);

            if (_rg is null)
            {
                _tags = [];
                _loadError = "Resource group not found.";
                return;
            }

            _tags = new Dictionary<string, string>(_rg.Tags, StringComparer.OrdinalIgnoreCase);
        }
        catch (Exception ex)
        {
            _tags = [];
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<string?> AddTagAsync(string tag, string value)
    {
        try
        {
            await TopazClient.CreateOrUpdateResourceGroupTag(SubscriptionId, DecodedName, tag, value);
            await LoadResourceGroupAsync();
            StateHasChanged();
            return null;
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }

    private async Task<string?> RemoveTagAsync(string key)
    {
        try
        {
            await TopazClient.DeleteResourceGroupTag(SubscriptionId, DecodedName, key);
            await LoadResourceGroupAsync();
            StateHasChanged();
            return null;
        }
        catch (Exception ex)
        {
            return ex.Message;
        }
    }
}