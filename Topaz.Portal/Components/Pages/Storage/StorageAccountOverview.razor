@page "/portal/storage/{SubscriptionId:guid}/{ResourceGroupName}/{StorageAccountName}"
@using System.Net
@using Topaz.Portal.Models.Storage
@inject ITopazClient TopazClient
@inject NavigationManager Nav

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/portal/storage">Storage accounts</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">@DecodedSa</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@DecodedSa</h1>

<StorageAccountDetailsShell SubscriptionId="SubscriptionId"
                             ResourceGroupName="@DecodedRg"
                             StorageAccountName="@DecodedSa">
    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger" role="alert">@_error</div>
    }
    else if (_sa is null)
    {
        <p class="mb-0">Storage account not found.</p>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <h5 class="card-title mb-0">Essentials</h5>
                    <button class="btn btn-sm btn-outline-danger"
                            @onclick="() => _showDeleteConfirm = true"
                            disabled="@_deletingBusy">
                        Delete
                    </button>
                </div>

                @if (_showDeleteConfirm)
                {
                    <div class="alert alert-warning d-flex align-items-center justify-content-between" role="alert">
                        <span>Delete storage account <strong>@(_sa.Name)</strong>? This cannot be undone.</span>
                        <div class="d-flex gap-2 ms-3">
                            <button class="btn btn-sm btn-danger"
                                    @onclick="DeleteStorageAccountAsync"
                                    disabled="@_deletingBusy">
                                Confirm delete
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => _showDeleteConfirm = false"
                                    disabled="@_deletingBusy">
                                Cancel
                            </button>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_deleteError))
                {
                    <div class="alert alert-danger" role="alert">@_deleteError</div>
                }

                <div class="row g-0">
                    <div class="col-12 col-xl-6">
                        <dl class="row mb-0 essentials-grid">
                            <dt class="col-5 text-muted fw-normal">Resource group</dt>
                            <dd class="col-7">
                                <a href="/resource-groups/@SubscriptionId:D/@WebUtility.UrlEncode(_sa.ResourceGroupName ?? "")">
                                    @(_sa.ResourceGroupName ?? "-")
                                </a>
                            </dd>

                            <dt class="col-5 text-muted fw-normal">Location</dt>
                            <dd class="col-7">@(_sa.Location ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Subscription</dt>
                            <dd class="col-7">@(_sa.SubscriptionName ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Subscription ID</dt>
                            <dd class="col-7"><small class="font-monospace">@(_sa.SubscriptionId ?? "-")</small></dd>
                        </dl>
                    </div>

                    <div class="col-12 col-xl-6">
                        <dl class="row mb-0 essentials-grid">
                            <dt class="col-5 text-muted fw-normal">Disk state</dt>
                            <dd class="col-7">@GetDiskState(_sa.StatusOfPrimary)</dd>

                            <dt class="col-5 text-muted fw-normal">Performance</dt>
                            <dd class="col-7">@GetPerformanceTier(_sa.SkuName)</dd>

                            <dt class="col-5 text-muted fw-normal">Replication</dt>
                            <dd class="col-7">@GetReplicationDescription(_sa.SkuName)</dd>

                            <dt class="col-5 text-muted fw-normal">Account kind</dt>
                            <dd class="col-7">@GetKindDescription(_sa.Kind)</dd>

                            <dt class="col-5 text-muted fw-normal">Provisioning state</dt>
                            <dd class="col-7">@(_sa.ProvisioningState ?? "-")</dd>

                            <dt class="col-5 text-muted fw-normal">Created</dt>
                            <dd class="col-7">@(_sa.CreatedOn?.LocalDateTime.ToString("g") ?? "-")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    }
</StorageAccountDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string StorageAccountName { get; set; } = "";

    private bool _loading = true;
    private string? _error;
    private StorageAccountDto? _sa;

    private bool _showDeleteConfirm;
    private bool _deletingBusy;
    private string? _deleteError;

    private string DecodedRg => WebUtility.UrlDecode(ResourceGroupName);
    private string DecodedSa => WebUtility.UrlDecode(StorageAccountName);

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _sa = await TopazClient.GetStorageAccount(SubscriptionId, DecodedRg, DecodedSa);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DeleteStorageAccountAsync()
    {
        _deleteError = null;
        _deletingBusy = true;

        try
        {
            await TopazClient.DeleteStorageAccount(SubscriptionId, DecodedRg, DecodedSa);
            Nav.NavigateTo("/portal/storage");
        }
        catch (Exception ex)
        {
            _deleteError = ex.Message;
            _showDeleteConfirm = false;
        }
        finally
        {
            _deletingBusy = false;
        }
    }

    private static string GetDiskState(string? status) => status?.ToLowerInvariant() switch
    {
        "available"   => "Available",
        "unavailable" => "Unavailable",
        _             => status ?? "-"
    };

    private static string GetPerformanceTier(string? skuName) =>
        skuName?.StartsWith("Premium", StringComparison.OrdinalIgnoreCase) == true ? "Premium" :
        skuName?.StartsWith("Standard", StringComparison.OrdinalIgnoreCase) == true ? "Standard" :
        skuName ?? "-";

    private static string GetReplicationDescription(string? skuName) => skuName?.ToUpperInvariant() switch
    {
        "STANDARD_LRS"    => "Locally-redundant storage (LRS)",
        "STANDARD_GRS"    => "Geo-redundant storage (GRS)",
        "STANDARD_RAGRS"  => "Read-access geo-redundant storage (RA-GRS)",
        "STANDARD_ZRS"    => "Zone-redundant storage (ZRS)",
        "STANDARD_GZRS"   => "Geo-zone-redundant storage (GZRS)",
        "STANDARD_RAGZRS" => "Read-access geo-zone-redundant storage (RA-GZRS)",
        "PREMIUM_LRS"     => "Locally-redundant storage (LRS)",
        "PREMIUM_ZRS"     => "Zone-redundant storage (ZRS)",
        _                 => skuName ?? "-"
    };

    private static string GetKindDescription(string? kind) => kind switch
    {
        "StorageV2"        => "StorageV2 (general purpose v2)",
        "Storage"          => "Storage (general purpose v1)",
        "BlobStorage"      => "BlobStorage",
        "BlockBlobStorage" => "BlockBlobStorage",
        "FileStorage"      => "FileStorage",
        _                  => kind ?? "-"
    };
}
