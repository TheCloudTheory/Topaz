@using System.Net

<div class="row g-3">
    <div class="col-12 col-lg-3">
        <div class="card">
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <NavLink class="list-group-item list-group-item-action"
                             href="@OverviewHref"
                             Match="NavLinkMatch.All">
                        Overview
                    </NavLink>

                    <NavLink class="list-group-item list-group-item-action"
                             href="@IamHref">
                        IAM
                    </NavLink>

                    <NavLink class="list-group-item list-group-item-action"
                             href="@TagsHref">
                        Tags
                    </NavLink>

                    <NavLink class="list-group-item list-group-item-action"
                             href="@LogsHref">
                        Logs
                    </NavLink>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-9">
        @ChildContent
    </div>
</div>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }
    [Parameter] public string ResourceGroupName { get; set; } = "";
    [Parameter] public string ComponentName { get; set; } = "";
    [Parameter] public RenderFragment ChildContent { get; set; } = default!;

    private string EncodedRg => WebUtility.UrlEncode(ResourceGroupName);
    private string EncodedName => WebUtility.UrlEncode(ComponentName);

    private string OverviewHref => $"/portal/insights/{SubscriptionId:D}/{EncodedRg}/{EncodedName}";
    private string IamHref => $"/portal/insights/{SubscriptionId:D}/{EncodedRg}/{EncodedName}/iam";
    private string TagsHref => $"/portal/insights/{SubscriptionId:D}/{EncodedRg}/{EncodedName}/tags";
    private string LogsHref => $"/portal/insights/{SubscriptionId:D}/{EncodedRg}/{EncodedName}/logs";
}
