@* Topaz.Portal/Components/Pages/Subscription/SubscriptionIam.razor *@
@page "/subscriptions/{SubscriptionId:guid}/iam"
@using Topaz.Portal.Models.Subscriptions
@inject ITopazClient TopazClient

<Breadcrumb>
    <BreadcrumbItem Href="/">Home</BreadcrumbItem>
    <BreadcrumbItem Href="/subscriptions">Subscriptions</BreadcrumbItem>
    <BreadcrumbItem Href="@($"/subscriptions/{SubscriptionId:D}")">@(_subscriptionName ?? "Subscription")</BreadcrumbItem>
    <BreadcrumbItem IsActive="true">IAM</BreadcrumbItem>
</Breadcrumb>

<h1 class="mb-3">@(_subscriptionName ?? "Subscription")</h1>

<SubscriptionDetailsShell SubscriptionId="SubscriptionId">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title mb-3">IAM</h5>
            <p class="mb-0 text-muted">
                IAM view goes here (role assignments, role definitions, principals, etc.).
            </p>
        </div>
    </div>
</SubscriptionDetailsShell>

@code {
    [Parameter] public Guid SubscriptionId { get; set; }

    private string? _subscriptionName;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            var resp = await TopazClient.ListSubscriptions();
            var subs = resp?.Value ?? [];
            var sub = subs.FirstOrDefault(s =>
                Guid.TryParse(s.SubscriptionId, out var id) && id == SubscriptionId);
            _subscriptionName = sub?.DisplayName;
        }
        catch
        {
            // Ignore errors loading subscription name
        }
    }
}