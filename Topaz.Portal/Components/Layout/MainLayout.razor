@inherits LayoutComponentBase
@using Topaz.Portal
@inject AccountSession AccountSession
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu/>
    </div>

    <main>
        <div class="top-row px-4">
            @if (!string.IsNullOrWhiteSpace(AccountSession.SelectedAccount))
            {
                <span class="me-2">Account: @AccountSession.SelectedAccount</span>
                <button class="terminal-toggle-btn"
                        title="Open Topaz CLI terminal"
                        aria-label="Open Topaz CLI terminal"
                        @onclick="() => _terminalPanel.Toggle()">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width:18px;height:18px;display:block" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M0 3a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3zm9.5 5.5h-3a.5.5 0 0 0 0 1h3a.5.5 0 0 0 0-1zm-6.354-.354a.5.5 0 1 0 .708.708l2-2a.5.5 0 0 0 0-.708l-2-2a.5.5 0 1 0-.708.708L4.793 6.5 3.146 7.854z"/>
                    </svg>
                </button>
                <a href="" @onclick="SignOutAsync" @onclick:preventDefault="true">Sign out</a>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<TerminalPanel @ref="_terminalPanel" />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private TerminalPanel _terminalPanel = default!;

    private async Task SignOutAsync()
    {
        await AccountSession.SignOutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }
}