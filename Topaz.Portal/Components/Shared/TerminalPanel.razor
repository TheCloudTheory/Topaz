@implements IDisposable
@inject IJSRuntime JS
@inject ICliSuggestionService SuggestionService
@inject ITopazClient TopazClient
@inject ICliExecutionService CliExecutionService
@using Topaz.Portal.Models
@using Topaz.Portal.Models.Cli
@using Topaz.Portal.Services

@if (_isOpen)
{
    <div class="terminal-overlay" style="height: @(_height)px" role="region" aria-label="Topaz CLI terminal">
        <div class="terminal-resize-handle"
             @onmousedown="OnResizeMouseDown"
             @onmousedown:preventDefault="true">
            <div class="terminal-resize-grip"></div>
        </div>

        <div class="terminal-header">
            <span class="terminal-title">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;display:inline-block;margin-right:0.4rem;vertical-align:middle" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M0 3a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3zm9.5 5.5h-3a.5.5 0 0 0 0 1h3a.5.5 0 0 0 0-1zm-6.354-.354a.5.5 0 1 0 .708.708l2-2a.5.5 0 0 0 0-.708l-2-2a.5.5 0 1 0-.708.708L4.793 6.5 3.146 7.854z"/>
                </svg>Topaz CLI
            </span>
            <button class="terminal-close-btn" @onclick="Close" title="Close terminal" aria-label="Close terminal">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:14px;height:14px;display:block" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708z"/>
                </svg>
            </button>
        </div>

        <div class="terminal-output" @ref="_outputRef">
            <div class="terminal-welcome">
                <pre class="terminal-welcome-logo">  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
     в–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в•ҡв•җв•җв–Ҳв–Ҳв–Ҳв•”в•қ
     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв–Ҳв•”в•қ 
     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•қ в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘ в–Ҳв–Ҳв–Ҳв•”в•қ  
     в–Ҳв–Ҳв•‘   в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
     в•ҡв•җв•қ    в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ     в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ</pre>
                @if (!_welcomeReady)
                {
                    <p class="terminal-welcome-meta">Connecting to Topaz HostвҖҰ</p>
                }
                else if (_hostInfo is not null)
                {
                    <p class="terminal-welcome-meta">
                        Azure Emulator&nbsp;&nbsp;вҖў&nbsp;&nbsp;v@(_hostInfo.Version)
                        &nbsp;&nbsp;вҖў&nbsp;&nbsp;<span class="terminal-welcome-status terminal-welcome-status--healthy">вң“ @(_hostInfo.Status)</span>
                    </p>
                }
                else
                {
                    <p class="terminal-welcome-meta">
                        Azure Emulator&nbsp;&nbsp;вҖў&nbsp;&nbsp;<span class="terminal-welcome-status terminal-welcome-status--offline">вң— Host unreachable</span>
                    </p>
                }
                <p class="terminal-welcome-hint">Type a command or use вҶ‘вҶ“ to browse suggestions. Tab or Enter to select.</p>
            </div>

            @foreach (var entry in _history)
            {
                <div class="terminal-entry">
                    <span class="terminal-prompt">topaz&gt;</span>
                    <span class="terminal-command">@entry.Command</span>
                </div>
                @if (entry.IsExecuting)
                {
                    <div class="terminal-result terminal-result--executing">ExecutingвҖҰ</div>
                }
                else if (!string.IsNullOrEmpty(entry.Output))
                {
                    <div class="terminal-result @(entry.IsError ? "terminal-result--error" : "")">@entry.Output</div>
                }
            }
        </div>

        <div class="terminal-input-wrapper">
            @if (_suggestions.Count > 0)
            {
                <div class="terminal-suggestions" role="listbox" aria-label="Command suggestions">
                    @for (var i = 0; i < _suggestions.Count; i++)
                    {
                        var suggestion = _suggestions[i];
                        var index = i;
                        var isSelected = index == _selectedIndex;

                        <div class="terminal-suggestion-item @(isSelected ? "terminal-suggestion-item--selected" : "")"
                             role="option"
                             aria-selected="@isSelected"
                             @onmousedown="() => SelectSuggestion(suggestion)"
                             @onmouseenter="() => _selectedIndex = index">
                            <div class="terminal-suggestion-main">
                                <span class="terminal-suggestion-name">@suggestion.Name</span>
                                @if (isSelected && suggestion.Examples.Length > 0)
                                {
                                    <div class="terminal-suggestion-examples">
                                        @foreach (var example in suggestion.Examples)
                                        {
                                            <div class="terminal-suggestion-example">
                                                <span class="terminal-suggestion-example-title">@example.Title</span>
                                                <code class="terminal-suggestion-example-cmd">@example.Command</code>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                            <span class="terminal-suggestion-desc">@suggestion.Description</span>
                        </div>
                    }
                </div>
            }

            <div class="terminal-input-row">
                <span class="terminal-prompt">topaz&gt;</span>
                <input
                    class="terminal-input"
                    type="text"
                    placeholder="Enter commandвҖҰ"
                    aria-label="Command input"
                    aria-autocomplete="list"
                    value="@_currentInput"
                    @oninput="OnInputChanged"
                    @onkeydown="OnKeyDown"
                    @ref="_inputRef" />
            </div>
        </div>
    </div>
}

@code {
    private bool _isOpen;
    private string _currentInput = string.Empty;
    private readonly List<TerminalEntry> _history = [];
    private ElementReference _outputRef;
    private ElementReference _inputRef;

    private double _height = 320;
    private const double MinHeight = 150;
    private const double MaxHeight = 800;

    private double _dragStartY;
    private double _dragStartHeight;

    private List<CliCommandModel> _suggestions = [];
    private int _selectedIndex = -1;

    private HostInfoDto? _hostInfo;
    private bool _welcomeReady;

    public void Open()
    {
        _isOpen = true;
        StateHasChanged();
        if (!_welcomeReady)
            _ = LoadWelcomeAsync();
    }

    public void Close()
    {
        _isOpen = false;
        StateHasChanged();
    }

    public void Toggle()
    {
        if (_isOpen) Close();
        else Open();
    }

    private void OnInputChanged(ChangeEventArgs e)
    {
        _currentInput = e.Value?.ToString() ?? string.Empty;
        _suggestions = [..SuggestionService.GetSuggestions(_currentInput)];
        _selectedIndex = _suggestions.Count > 0 ? 0 : -1;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowDown":
                if (_suggestions.Count > 0)
                    _selectedIndex = (_selectedIndex + 1) % _suggestions.Count;
                return;

            case "ArrowUp":
                if (_suggestions.Count > 0)
                    _selectedIndex = (_selectedIndex - 1 + _suggestions.Count) % _suggestions.Count;
                return;

            case "Tab":
                if (_selectedIndex >= 0 && _selectedIndex < _suggestions.Count)
                {
                    SelectSuggestion(_suggestions[_selectedIndex]);
                    await FocusInputAsync();
                }
                return;

            case "Escape":
                _suggestions = [];
                _selectedIndex = -1;
                return;

            case "Enter":
                if (_selectedIndex >= 0 && _selectedIndex < _suggestions.Count)
                {
                    SelectSuggestion(_suggestions[_selectedIndex]);
                    await FocusInputAsync();
                    return;
                }

                var command = _currentInput.Trim();
                if (string.IsNullOrEmpty(command)) return;

                var entry = new TerminalEntry(command) { IsExecuting = true };
                _history.Add(entry);
                _currentInput = string.Empty;
                _suggestions = [];
                _selectedIndex = -1;

                StateHasChanged();
                await ScrollOutputToBottomAsync();

                var result = await CliExecutionService.ExecuteAsync(command);
                entry.Output = result?.Output ?? string.Empty;
                entry.IsError = result?.IsError ?? false;
                entry.IsExecuting = false;

                await ScrollOutputToBottomAsync();
                return;
        }
    }

    private async Task LoadWelcomeAsync()
    {
        _hostInfo = await TopazClient.GetHostInfoAsync();
        _welcomeReady = true;
        await InvokeAsync(StateHasChanged);
    }

    private void SelectSuggestion(CliCommandModel suggestion)    {
        var parts = new List<string> { suggestion.Name };

        foreach (var option in suggestion.Options)
        {
            var isRequired = option.Required ||
                             option.Description.StartsWith("(Required)", StringComparison.OrdinalIgnoreCase);
            if (!isRequired) continue;

            // Prefer --long-name over -s short name
            var preferredName = option.Names
                .Split(',')
                .Select(n => n.Trim())
                .OrderByDescending(n => n.StartsWith("--"))
                .First();

            var placeholder = preferredName.TrimStart('-');
            parts.Add($"{preferredName} <{placeholder}>");
        }

        _currentInput = string.Join(" ", parts);
        _suggestions = [];
        _selectedIndex = -1;
    }

    private async Task FocusInputAsync()
    {
        await JS.InvokeVoidAsync("eval", "document.querySelector('.terminal-input')?.focus()");
    }

    private async Task ScrollOutputToBottomAsync()
    {
        await JS.InvokeVoidAsync("eval",
            "var el = document.querySelector('.terminal-output'); if (el) el.scrollTop = el.scrollHeight;");
    }

    private async Task OnResizeMouseDown(MouseEventArgs e)
    {
        _dragStartY = e.ClientY;
        _dragStartHeight = _height;
        var dotnetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("terminalResize.start", dotnetRef, _dragStartY, _dragStartHeight);
    }

    [JSInvokable]
    public void SetHeight(double height)
    {
        _height = height;
        StateHasChanged();
    }

    public void Dispose() { }

    private sealed class TerminalEntry(string command)
    {
        public string Command { get; } = command;
        public string Output { get; set; } = string.Empty;
        public bool IsError { get; set; }
        public bool IsExecuting { get; set; }
    }
}
