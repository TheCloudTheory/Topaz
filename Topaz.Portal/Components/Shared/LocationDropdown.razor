@using Topaz.Portal.Models.Locations

<div class="mb-3">
    <label class="form-label">Location</label>
    <select class="form-select"
            value="@SelectedLocation"
            @onchange="OnLocationSelectionChanged"
            disabled="@Disabled">
        <option value="">Select a location…</option>
        @foreach (var location in AzureLocations.CommonLocations)
        {
            <option value="@location.Code">
                @location.DisplayName (@location.Code)
            </option>
        }
    </select>
</div>

@code {
    [Parameter]
    public string? SelectedLocation { get; set; }

    [Parameter]
    public EventCallback<string> OnLocationChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private async Task OnLocationSelectionChanged(ChangeEventArgs e)
    {
        var selectedValue = e.Value as string ?? string.Empty;
        SelectedLocation = selectedValue;
        await OnLocationChanged.InvokeAsync(selectedValue);
    }
}
