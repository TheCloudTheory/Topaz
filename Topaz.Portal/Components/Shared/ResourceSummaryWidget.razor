@using Topaz.Portal.Models.Storage
@using Topaz.Portal.Models.KeyVaults
@using Topaz.Portal.Models.ManagedIdentities
@using Topaz.Portal.Models.EventHubs
@using Topaz.Portal.Models.ServiceBus
@using Topaz.Portal.Models.VirtualMachines
@using Topaz.Portal.Models.VirtualNetworks
@inject ITopazClient TopazClient

<div class="card h-100">
    <div class="card-body">
        <h5 class="card-title mb-3">
            <span class="bi bi-bar-chart-line me-2 text-primary" aria-hidden="true"></span>Resource summary
        </h5>

        @if (_loading)
        {
            <p class="text-muted small mb-0">Loading…</p>
        }
        else if (_error is not null)
        {
            <div class="alert alert-danger alert-sm py-1 px-2 mb-0 small" role="alert">@_error</div>
        }
        else
        {
            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center h-100 position-relative">
                        <div class="display-6 fw-bold text-primary">@_subscriptionCount</div>
                        <div class="small text-muted mt-1">Subscriptions</div>
                        <a href="/subscriptions" class="small stretched-link text-decoration-none">View →</a>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center h-100 position-relative">
                        <div class="display-6 fw-bold text-primary">@_resourceGroupCount</div>
                        <div class="small text-muted mt-1">Resource groups</div>
                        <a href="/resource-groups" class="small stretched-link text-decoration-none">View →</a>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center h-100 position-relative">
                        <div class="display-6 fw-bold text-primary">@_storageCount</div>
                        <div class="small text-muted mt-1">Storage accounts</div>
                        <a href="/portal/storage" class="small stretched-link text-decoration-none">View →</a>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center h-100 position-relative">
                        <div class="display-6 fw-bold text-primary">@_keyVaultCount</div>
                        <div class="small text-muted mt-1">Key vaults</div>
                        <a href="/key-vault" class="small stretched-link text-decoration-none">View →</a>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center h-100 position-relative">
                        <div class="display-6 fw-bold text-primary">@_managedIdentityCount</div>
                        <div class="small text-muted mt-1">Managed identities</div>
                        <a href="/managed-identities" class="small stretched-link text-decoration-none">View →</a>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center h-100 position-relative">
                        <div class="display-6 fw-bold text-primary">@_eventHubNamespaceCount</div>
                        <div class="small text-muted mt-1">Event Hub namespaces</div>
                        <a href="/portal/event-hubs" class="small stretched-link text-decoration-none">View →</a>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center h-100 position-relative">
                        <div class="display-6 fw-bold text-primary">@_serviceBusNamespaceCount</div>
                        <div class="small text-muted mt-1">Service Bus namespaces</div>
                        <a href="/portal/service-bus" class="small stretched-link text-decoration-none">View →</a>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center h-100 position-relative">
                        <div class="display-6 fw-bold text-primary">@_virtualMachineCount</div>
                        <div class="small text-muted mt-1">Virtual machines</div>
                        <a href="/portal/virtual-machines" class="small stretched-link text-decoration-none">View →</a>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="border rounded p-3 text-center h-100 position-relative">
                        <div class="display-6 fw-bold text-primary">@_virtualNetworkCount</div>
                        <div class="small text-muted mt-1">Virtual networks</div>
                        <a href="/portal/virtual-networks" class="small stretched-link text-decoration-none">View →</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private string? _error;
    private int _storageCount;
    private int _keyVaultCount;
    private int _subscriptionCount;
    private int _resourceGroupCount;
    private int _managedIdentityCount;
    private int _eventHubNamespaceCount;
    private int _serviceBusNamespaceCount;
    private int _virtualMachineCount;
    private int _virtualNetworkCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var storageTask = TopazClient.ListStorageAccounts();
            var keyVaultTask = TopazClient.ListKeyVaults();
            var subsTask = TopazClient.ListSubscriptions();
            var rgsTask = TopazClient.ListResourceGroups();
            var miTask = TopazClient.ListManagedIdentities();
            var ehTask = TopazClient.ListEventHubNamespaces();
            var sbTask = TopazClient.ListServiceBusNamespaces();
            var vmTask = TopazClient.ListVirtualMachines();
            var vnetTask = TopazClient.ListVirtualNetworks();

            await Task.WhenAll(storageTask, keyVaultTask, subsTask, rgsTask, miTask, ehTask, sbTask, vmTask, vnetTask);

            _storageCount = (await storageTask).Value?.Length ?? 0;
            _keyVaultCount = (await keyVaultTask).Value?.Length ?? 0;
            _subscriptionCount = (await subsTask).Value?.Length ?? 0;
            _resourceGroupCount = (await rgsTask).Value?.Length ?? 0;
            _managedIdentityCount = (await miTask).Value?.Length ?? 0;
            _eventHubNamespaceCount = (await ehTask).Value?.Length ?? 0;
            _serviceBusNamespaceCount = (await sbTask).Value?.Length ?? 0;
            _virtualMachineCount = (await vmTask).Value?.Length ?? 0;
            _virtualNetworkCount = (await vnetTask).Value?.Length ?? 0;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
